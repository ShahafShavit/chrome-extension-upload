# Local run: copy to `.env` and fill in. Never commit `.env`.
#
# GitHub Actions sets inputs using env keys with HYPHENS (e.g. INPUT_FILE-PATH).
# @actions/core getInput("file-path") reads process.env["INPUT_FILE-PATH"].
# You may use either form below; run-local.cjs copies *_PATH-style keys for you.
#
# Docs: https://github.com/actions/toolkit/issues/629

# Preferred (matches the runner exactly):
INPUT_FILE-PATH=./extension.zip
INPUT_EXTENSION-ID=your_extension_id_here
INPUT_PUBLISHER-ID=
INPUT_CLIENT-ID=your_oauth_client_id.apps.googleusercontent.com
INPUT_CLIENT-SECRET=your_oauth_client_secret
INPUT_REFRESH-TOKEN=your_refresh_token

# Or underscore style (also accepted by npm run run:local):
# INPUT_FILE_PATH=./extension.zip
# INPUT_EXTENSION_ID=...

INPUT_GLOB=false
INPUT_PUBLISH=false
INPUT_PUBLISH-TARGET=default

# Optional:
# ACTIONS_STEP_DEBUG=true
