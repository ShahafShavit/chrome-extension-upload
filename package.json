{
  "name": "chrome-extension-upload",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to upload and publish Chrome extensions using the Chrome Web Store API (v2 with publisher ID, legacy v1 compatible without it).",
  "main": "lib/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/**/*.ts",
    "pack": "ncc build lib/main.js -o dist",
    "run:local": "npm run build && node scripts/run-local.cjs",
    "all": "npm run build && npm run format && npm run lint && npm run pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShahafShavit/chrome-extension-upload.git"
  },
  "keywords": [
    "github-actions",
    "chrome-extension",
    "chrome-web-store",
    "chromewebstore",
    "ci",
    "publish"
  ],
  "author": "ShahafShavit",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "glob": "^7.1.6"
  },
  "devDependencies": {
    "@types/glob": "^7.1.1",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^5.3.0",
    "@typescript-eslint/parser": "^5.3.0",
    "@vercel/ncc": "^0.36.0",
    "dotenv": "^17.4.1",
    "eslint": "^8.2.0",
    "prettier": "^3.4.2",
    "typescript": "^5.5.0"
  }
}
